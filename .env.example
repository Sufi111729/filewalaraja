# Frontend-only OTP mail config (EmailJS)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Optional API base for production or remote backend.
# Keep empty in local dev to use Vite /api proxy.
VITE_API_BASE=

# Local dev proxy target for /api requests.
VITE_DEV_API_PROXY_TARGET=http://localhost:8080
